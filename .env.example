# Application
NODE_ENV=development
PORT=5000
API_VERSION=v1

# MongoDB
MONGODB_URI=mongodb://localhost:27017/orderflow

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=dev

# Scheduler (AWS EventBridge)
# Set this and send it as x-api-key header from EventBridge API destination
SCHEDULER_API_KEY=your-secure-scheduler-api-key
